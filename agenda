<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Agenda de Eventos</title>

  <style>
    :root {
      --bg: #050510;
      --bg-2: #0b0b1f;
      --card: rgba(255, 255, 255, 0.08);
      --card-strong: rgba(255, 255, 255, 0.14);
      --border: rgba(255, 255, 255, 0.16);

      --primary: #8b5cf6;
      --secondary: #22d3ee;
      --accent: #f97316;
      --green: #22c55e;

      --text: #ffffff;
      --muted: #b9b9d4;
      --radius: 24px;
      --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      font-family: Inter, Arial, sans-serif;
      background:
        radial-gradient(circle at 15% 10%, rgba(139, 92, 246, 0.35), transparent 30%),
        radial-gradient(circle at 85% 20%, rgba(34, 211, 238, 0.22), transparent 35%),
        radial-gradient(circle at 50% 95%, rgba(249, 115, 22, 0.16), transparent 35%),
        linear-gradient(145deg, var(--bg), var(--bg-2));
      color: var(--text);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
      background-size: 44px 44px;
      mask-image: linear-gradient(to bottom, black, transparent 85%);
      pointer-events: none;
      z-index: -2;
    }

    .orb {
      position: fixed;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      filter: blur(12px);
      opacity: 0.22;
      pointer-events: none;
      z-index: -1;
      animation: float 9s ease-in-out infinite;
    }

    .orb.one {
      background: var(--primary);
      top: 10%;
      left: -90px;
    }

    .orb.two {
      background: var(--secondary);
      right: -100px;
      bottom: 12%;
      animation-delay: -3s;
    }

    .orb.three {
      background: var(--accent);
      width: 180px;
      height: 180px;
      top: 55%;
      left: 45%;
      animation-delay: -6s;
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0) scale(1);
      }

      50% {
        transform: translateY(-26px) scale(1.06);
      }
    }

    .page {
      width: min(1180px, calc(100% - 32px));
      margin: 0 auto;
      padding: 40px 0 60px;
    }

    .hero {
      margin-bottom: 26px;
    }

    .hero-card,
    .calendar-card,
    .event-panel {
      background: linear-gradient(145deg, rgba(255,255,255,0.13), rgba(255,255,255,0.045));
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      backdrop-filter: blur(20px);
      border-radius: var(--radius);
      position: relative;
      overflow: hidden;
    }

    .hero-card::before,
    .calendar-card::before,
    .event-panel::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent, rgba(255,255,255,0.13), transparent);
      transform: translateX(-120%);
      animation: shine 8s infinite;
      pointer-events: none;
    }

    @keyframes shine {
      0% {
        transform: translateX(-120%);
      }

      45%, 100% {
        transform: translateX(120%);
      }
    }

    .hero-card {
      padding: 34px;
      min-height: 260px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(34, 211, 238, 0.12);
      border: 1px solid rgba(34, 211, 238, 0.28);
      color: #d7fbff;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.3px;
      margin-bottom: 18px;
    }

    .pulse-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 0 rgba(34,197,94,0.7);
      animation: pulse 1.8s infinite;
    }

    @keyframes pulse {
      0% {
        box-shadow: 0 0 0 0 rgba(34,197,94,0.7);
      }

      70% {
        box-shadow: 0 0 0 10px rgba(34,197,94,0);
      }

      100% {
        box-shadow: 0 0 0 0 rgba(34,197,94,0);
      }
    }

    h1 {
      font-size: clamp(34px, 5vw, 68px);
      line-height: 0.96;
      letter-spacing: -2.4px;
      margin-bottom: 18px;
      max-width: 850px;
    }

    .gradient-text {
      background: linear-gradient(90deg, #fff, #c4b5fd, #67e8f9);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 0 50px rgba(139, 92, 246, 0.24);
    }

    .hero-card p {
      color: var(--muted);
      font-size: 16px;
      line-height: 1.7;
      max-width: 760px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-top: 26px;
    }

    .stat {
      padding: 16px;
      border-radius: 18px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
    }

    .stat strong {
      display: block;
      font-size: 24px;
      margin-bottom: 4px;
    }

    .stat span {
      font-size: 12px;
      color: var(--muted);
    }

    .content {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 24px;
    }

    .calendar-card {
      padding: 24px;
    }

    .calendar-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 20px;
    }

    .month-title {
      font-size: clamp(22px, 3vw, 34px);
      letter-spacing: -0.8px;
    }

    .nav-buttons {
      display: flex;
      gap: 8px;
    }

    .nav-buttons button {
      border: none;
      cursor: pointer;
      color: white;
      font-weight: 800;
      width: 52px;
      height: 44px;
      padding: 0;
      border-radius: 14px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      transition: transform 0.25s ease, background 0.25s ease;
    }

    .nav-buttons button:hover {
      transform: translateY(-3px);
      background: rgba(255,255,255,0.14);
    }

    .nav-buttons #todayMonth {
      width: auto;
      padding: 0 18px;
      background: linear-gradient(135deg, rgba(139,92,246,0.85), rgba(34,211,238,0.65));
    }

    .weekdays,
    .calendar {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 10px;
    }

    .weekday {
      text-align: center;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      padding-bottom: 4px;
    }

    .day {
      min-height: 118px;
      border-radius: 18px;
      padding: 12px;
      background: rgba(255,255,255,0.055);
      border: 1px solid rgba(255,255,255,0.09);
      transition: 0.25s ease;
      position: relative;
      overflow: hidden;
    }

    .day:hover {
      transform: translateY(-4px);
      border-color: rgba(34, 211, 238, 0.32);
      background: rgba(255,255,255,0.09);
    }

    .day.empty {
      opacity: 0.28;
      pointer-events: none;
    }

    .day.today {
      border-color: rgba(34, 211, 238, 0.75);
      box-shadow: inset 0 0 0 1px rgba(34, 211, 238, 0.28);
    }

    .day-number {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-weight: 900;
      margin-bottom: 9px;
    }

    .today-tag {
      font-size: 10px;
      color: #03131a;
      background: #67e8f9;
      padding: 4px 7px;
      border-radius: 999px;
    }

    .event-chip {
      display: block;
      width: 100%;
      text-align: left;
      margin-top: 7px;
      padding: 8px 9px;
      border-radius: 12px;
      color: white;
      background: linear-gradient(135deg, rgba(139,92,246,0.95), rgba(34,211,238,0.78));
      font-size: 12px;
      font-weight: 800;
      text-decoration: none;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: 0.25s ease;
    }

    .event-chip:hover {
      transform: scale(1.03);
      filter: brightness(1.12);
    }

    .event-panel {
      padding: 24px;
      align-self: start;
      position: sticky;
      top: 20px;
    }

    .event-panel h2 {
      font-size: 22px;
      margin-bottom: 10px;
    }

    .event-panel p {
      color: var(--muted);
      line-height: 1.5;
      font-size: 14px;
      margin-bottom: 20px;
    }

    .event-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .event-item {
      padding: 16px;
      border-radius: 18px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.11);
      transition: 0.25s ease;
    }

    .event-item:hover {
      transform: translateY(-3px);
      background: rgba(255,255,255,0.1);
    }

    .event-date {
      color: var(--secondary);
      font-size: 12px;
      font-weight: 900;
      margin-bottom: 6px;
    }

    .event-name {
      font-weight: 900;
      margin-bottom: 12px;
      line-height: 1.35;
    }

    .link-button {
      width: 100%;
      border: none;
      cursor: pointer;
      color: white;
      font-weight: 800;
      border-radius: 13px;
      padding: 12px;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      box-shadow: 0 12px 32px rgba(34, 211, 238, 0.18);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 13px;
    }

    .link-button:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 46px rgba(139, 92, 246, 0.34);
    }

    .empty-message {
      color: var(--muted);
      font-size: 14px;
      padding: 18px;
      border: 1px dashed rgba(255,255,255,0.18);
      border-radius: 16px;
      text-align: center;
    }

    .footer-note {
      color: rgba(255,255,255,0.42);
      font-size: 12px;
      text-align: center;
      margin-top: 28px;
      line-height: 1.5;
    }

    @media (max-width: 960px) {
      .content {
        grid-template-columns: 1fr;
      }

      .event-panel {
        position: relative;
        top: auto;
      }
    }

    @media (max-width: 680px) {
      .page {
        width: min(100% - 22px, 1180px);
        padding-top: 20px;
      }

      .hero-card,
      .calendar-card,
      .event-panel {
        border-radius: 22px;
      }

      .hero-card {
        padding: 24px;
      }

      .stats {
        grid-template-columns: 1fr;
      }

      .calendar-top {
        align-items: flex-start;
        flex-direction: column;
      }

      .weekdays {
        gap: 5px;
      }

      .calendar {
        gap: 7px;
      }

      .weekday {
        font-size: 10px;
      }

      .day {
        min-height: 92px;
        padding: 8px;
        border-radius: 14px;
      }

      .day-number {
        font-size: 13px;
      }

      .today-tag {
        display: none;
      }

      .event-chip {
        font-size: 10px;
        padding: 7px;
      }
    }

    @media (max-width: 420px) {
      .calendar-card {
        padding: 14px;
      }

      .weekdays,
      .calendar {
        gap: 5px;
      }

      .day {
        min-height: 78px;
        padding: 6px;
      }

      .event-chip {
        margin-top: 5px;
        font-size: 9px;
      }

      h1 {
        letter-spacing: -1.5px;
      }
    }
  </style>
</head>

<body>
  <div class="orb one"></div>
  <div class="orb two"></div>
  <div class="orb three"></div>

  <main class="page">
    <section class="hero">
      <div class="hero-card">
        <div class="badge">
          <span class="pulse-dot"></span>
          Agenda oficial de eventos
        </div>

        <h1>
          Próximos <span class="gradient-text">eventos</span><br />
          em destaque
        </h1>

        <p>
          Confira a programação oficial do mês e escolha o evento desejado.
          Ao clicar no evento, você será redirecionado para a página de vendas.
        </p>

        <div class="stats">
          <div class="stat">
            <strong id="totalEvents">0</strong>
            <span>Eventos cadastrados</span>
          </div>

          <div class="stat">
            <strong id="monthEvents">0</strong>
            <span>Eventos neste mês</span>
          </div>

          <div class="stat">
            <strong>Online</strong>
            <span>Agenda atualizada</span>
          </div>
        </div>
      </div>
    </section>

    <section class="content">
      <div class="calendar-card">
        <div class="calendar-top">
          <h2 class="month-title" id="monthTitle">Agenda</h2>

          <div class="nav-buttons">
            <button id="prevMonth" aria-label="Mês anterior">‹</button>
            <button id="todayMonth" aria-label="Mês atual">Hoje</button>
            <button id="nextMonth" aria-label="Próximo mês">›</button>
          </div>
        </div>

        <div class="weekdays">
          <div class="weekday">Dom</div>
          <div class="weekday">Seg</div>
          <div class="weekday">Ter</div>
          <div class="weekday">Qua</div>
          <div class="weekday">Qui</div>
          <div class="weekday">Sex</div>
          <div class="weekday">Sáb</div>
        </div>

        <div class="calendar" id="calendar"></div>
      </div>

      <aside class="event-panel">
        <h2>Eventos do mês</h2>
        <p>Lista rápida com os eventos cadastrados no mês selecionado.</p>

        <div class="event-list" id="eventList"></div>
      </aside>
    </section>

    <p class="footer-note">
      Agenda oficial. Os eventos são gerenciados diretamente pelo administrador do site.
    </p>
  </main>

  <script>
    /*
      EDITE SEUS EVENTOS AQUI.

      Para adicionar um novo evento, copie este modelo:

      {
        date: "2026-07-20",
        name: "Nome do Evento",
        link: "https://seudominio.com/pagina-de-vendas"
      }

      Atenção:
      - Use a data no formato ANO-MÊS-DIA.
      - Exemplo: 2026-07-20.
      - O link deve começar com https://
    */

    const EVENTOS = [
      {
        date: "2026-07-05",
        name: "Baile Premium",
        link: "https://seudominio.com/vendas"
      },
      {
        date: "2026-07-13",
        name: "Sunset Experience",
        link: "https://seudominio.com/vendas"
      },
      {
        date: "2026-07-27",
        name: "Noite Especial",
        link: "https://seudominio.com/vendas"
      }
    ];

    const calendar = document.getElementById("calendar");
    const monthTitle = document.getElementById("monthTitle");
    const eventList = document.getElementById("eventList");
    const totalEvents = document.getElementById("totalEvents");
    const monthEvents = document.getElementById("monthEvents");

    const prevMonth = document.getElementById("prevMonth");
    const nextMonth = document.getElementById("nextMonth");
    const todayMonth = document.getElementById("todayMonth");

    const today = new Date();
    let currentMonth = today.getMonth();
    let currentYear = today.getFullYear();

    const monthNames = [
      "Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho",
      "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"
    ];

    function formatDate(year, month, day) {
      const mm = String(month + 1).padStart(2, "0");
      const dd = String(day).padStart(2, "0");
      return `${year}-${mm}-${dd}`;
    }

    function formatDateBR(dateString) {
      const [year, month, day] = dateString.split("-");
      return `${day}/${month}/${year}`;
    }

    function renderCalendar() {
      calendar.innerHTML = "";
      eventList.innerHTML = "";

      const firstDay = new Date(currentYear, currentMonth, 1).getDay();
      const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();

      monthTitle.textContent = `${monthNames[currentMonth]} ${currentYear}`;

      for (let i = 0; i < firstDay; i++) {
        const empty = document.createElement("div");
        empty.className = "day empty";
        calendar.appendChild(empty);
      }

      for (let day = 1; day <= daysInMonth; day++) {
        const dateKey = formatDate(currentYear, currentMonth, day);

        const dayEvents = EVENTOS.filter(event => event.date === dateKey);

        const dayBox = document.createElement("div");
        dayBox.className = "day";

        const isToday =
          day === today.getDate() &&
          currentMonth === today.getMonth() &&
          currentYear === today.getFullYear();

        if (isToday) {
          dayBox.classList.add("today");
        }

        dayBox.innerHTML = `
          <div class="day-number">
            <span>${day}</span>
            ${isToday ? `<span class="today-tag">Hoje</span>` : ""}
          </div>
        `;

        dayEvents.forEach(event => {
          const eventChip = document.createElement("a");
          eventChip.href = event.link;
          eventChip.target = "_blank";
          eventChip.rel = "noopener noreferrer";
          eventChip.className = "event-chip";
          eventChip.textContent = event.name;
          dayBox.appendChild(eventChip);
        });

        calendar.appendChild(dayBox);
      }

      renderEventList();
      updateStats();
    }

    function renderEventList() {
      const filteredEvents = EVENTOS
        .filter(event => {
          const [year, month] = event.date.split("-").map(Number);
          return year === currentYear && month === currentMonth + 1;
        })
        .sort((a, b) => a.date.localeCompare(b.date));

      monthEvents.textContent = filteredEvents.length;

      if (filteredEvents.length === 0) {
        eventList.innerHTML = `
          <div class="empty-message">
            Nenhum evento cadastrado neste mês.
          </div>
        `;
        return;
      }

      filteredEvents.forEach(event => {
        const item = document.createElement("div");
        item.className = "event-item";

        item.innerHTML = `
          <div class="event-date">${formatDateBR(event.date)}</div>
          <div class="event-name">${event.name}</div>

          <a class="link-button" href="${event.link}" target="_blank" rel="noopener noreferrer">
            Abrir página de vendas
          </a>
        `;

        eventList.appendChild(item);
      });
    }

    function updateStats() {
      totalEvents.textContent = EVENTOS.length;
    }

    prevMonth.addEventListener("click", () => {
      currentMonth--;

      if (currentMonth < 0) {
        currentMonth = 11;
        currentYear--;
      }

      renderCalendar();
    });

    nextMonth.addEventListener("click", () => {
      currentMonth++;

      if (currentMonth > 11) {
        currentMonth = 0;
        currentYear++;
      }

      renderCalendar();
    });

    todayMonth.addEventListener("click", () => {
      currentMonth = today.getMonth();
      currentYear = today.getFullYear();
      renderCalendar();
    });

    renderCalendar();
  </script>
</body>
</html>
